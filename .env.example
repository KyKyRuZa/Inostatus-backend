# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_USER=innostatus
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=innostatus_db
DATABASE_URL=postgresql://innostatus:your_secure_password_here@postgres:5432/innostatus_db

# ===========================================
# JWT Settings
# ===========================================
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# External Check API (Inostatus API)
# ===========================================
CHECK_API_BASE_URL=https://api.inostatus.ru/api
CHECK_API_KEY=your-api-key-from-inostatus
INTEGRATOR_ID=your-integrator-id

# Лимиты
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,txt,docx
POLLING_INTERVAL_SECONDS=5
POLLING_TIMEOUT_SECONDS=300

# ===========================================
# SMTP Email Settings
# ===========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SEND_EMAIL=info@inostatus.ru

# ===========================================
# Application Settings
# ===========================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DEBUG=false
